rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Public read on these collections
    match /menus/{menuId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /events/{eventId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /gallery/{imageId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Content (rooms, settings) — public read, auth write
    match /content/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
