# Copy this file to .env.local and fill in your Firebase project values.
# Get these from Firebase Console → Project Settings → General → Your apps → SDK setup

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Google Maps embed URL (from Google Maps → Share → Embed a map → copy src URL)
VITE_GOOGLE_MAPS_EMBED_URL=

# Net Affinity booking engine URL
VITE_NETAFFINITY_BOOKING_URL=https://bookings.gleesons.ie

# Net Affinity voucher portal URL
VITE_NETAFFINITY_VOUCHER_URL=

# ResDiary widget embed URL (from ResDiary account)
VITE_RESDIARY_WIDGET_URL=
